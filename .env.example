# Copy to `.env` for local development (`npm run dev`).
# For CloudFront/GitHub Actions deploy, set these as build-time environment variables.
# Values come from HCP Terraform outputs (workspace ubc-eml-virtual-soils).

# API Gateway base URL — no trailing slash
VITE_API_URL=https://YOUR_API_ID.execute-api.ca-central-1.amazonaws.com

# Cognito (from HCP outputs: cognito_user_pool_id, cognito_user_pool_client_id, cognito_hosted_ui_domain)
VITE_COGNITO_USER_POOL_ID=ca-central-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_OAUTH_DOMAIN=xxxxxxxx.auth.ca-central-1.amazoncognito.com

# Optional: fixed origin for OAuth when not using window.location (rare for local dev)
# VITE_APP_ORIGIN=http://localhost:5173
