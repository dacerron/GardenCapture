# Copy to `.env` at this repo root for local dev.
# Vite loads this file for both apps (envDir points here).
# For CloudFront deploy, set the same names as build-time CI secrets.
# Values come from HCP Terraform outputs (workspace ubc-eml-virtual-soils).

# --- Viewer (npm run dev:viewer → http://localhost:5173) ---
VITE_PUBLIC_API_URL=https://YOUR_API_ID.execute-api.ca-central-1.amazonaws.com

# --- Admin (npm run dev:admin → http://localhost:5174) ---
VITE_ADMIN_API_URL=https://YOUR_API_ID.execute-api.ca-central-1.amazonaws.com
VITE_COGNITO_USER_POOL_ID=ca-central-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Amplify auth.ts accepts either name (HCP output is cognito_hosted_ui_domain):
VITE_COGNITO_OAUTH_DOMAIN=xxxxxxxx.auth.ca-central-1.amazoncognito.com

# Optional redirect overrides (comma-separated full URLs)
# VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5174/
# VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5174/
